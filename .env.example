# Variables de entorno de CyT_dashboard2.0. Copiá a .env (está en .gitignore).

# ── IA ───────────────────────────────────────────────────────
# Gemini: usado por el chatbot (api/chat.js).
GEMINI_API_KEY=your_api_key_here
# OpenAI: usado para los resúmenes del email en el seguimiento (lib/summarize.js).
# Sin OPENAI_API_KEY, el resumen cae al sumario oficial del proyecto.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email / suscripciones (Resend) ───────────────────────────
RESEND_API_KEY=
# Opcional: id de la audiencia de Resend. Si no está, usa contactos globales.
RESEND_AUDIENCE_ID=
# Remitente verificado en Resend.
EMAIL_FROM=Seguimiento CyT <onboarding@resend.dev>
# Secret para firmar los tokens de confirmación/baja. Mínimo 24 caracteres.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUBSCRIBE_SECRET=
# Opcional: vida de los tokens en ms (default 7 días).
# SUBSCRIBE_TOKEN_TTL_MS=604800000

# ── Sitio ────────────────────────────────────────────────────
# URL pública del sitio (para los links de confirmación/baja en los emails).
SITE_URL=https://cytdashboard.vercel.app
